# ~/.profile: executed by the command interpreter for login shells.
# This file is not read by bash(1), if ~/.bash_profile or ~/.bash_login
# exists.
# see /usr/share/doc/bash/examples/startup-files for examples.
# the files are located in the bash-doc package.

# the default umask is set in /etc/profile; for setting the umask
# for ssh logins, install and configure the libpam-umask package.
#umask 022

# if running bash
if [ -n "$BASH_VERSION" ]; then
    # include .bashrc if it exists
    if [ -f "$HOME/.bashrc" ]; then
	. "$HOME/.bashrc"
    fi
fi

# set PATH so it includes user's private bin if it exists
if [ -d "$HOME/bin" ] ; then
    PATH="$HOME/bin:$PATH"
fi

# set PATH so it includes user's private bin if it exists
if [ -d "$HOME/.local/bin" ] ; then
    PATH="$HOME/.local/bin:$PATH"
fi
export QTPATH=/home/ubuntu/qt6
export PATH=$QTPATH/bin:$PATH
export LD_LIBRARY_PATH=$QTPATH/lib:$LD_LIBRARY_PATH

BASE_CROSSPLAT_LOGOUT=1
CROSSPLAT_HOME=$HOME/crossplat
CRSPLTSRCPATH=$HOME/crossplatsrc
CROSSPLAT_OBJDIR=$HOME/crossplatobj

EXAM_CROSS_PATH=$HOME/example

export BASE_CROSSPLAT_LOGOUT CROSSPLAT_HOME CRSPLTSRCPATH CROSSPLAT_OBJDIR EXAM_CROSS_PATH

LD_LIBRARY_PATH=$LD_LIBRARY_PATH:$CROSSPLAT_HOME/lib:$EXAM_CROSS_PATH/lib
PATH=$PATH:$HOME/.local/bin:$HOME/bin:$CROSSPLAT_HOME/bin:$EXAM_CROSS_PATH/bin

export PATH LD_LIBRARY_PATH